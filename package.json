{
  "name": "fleetguard-saas-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Multi-tenant school transportation SaaS platform",
  "license": "MIT",
  "workspaces": [
    "apps/web",
    "packages/shared",
    "packages/supabase"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "start": "npm run start -w apps/web",
    "lint": "npm run lint -w apps/web",
    "test": "npm run test -w apps/web",
    "db:migrate": "cd packages/supabase && npm run migrate",
    "db:seed": "cd packages/supabase && npm run seed",
    "setup": "npm install && npm run db:migrate",
    "clean": "npm run clean -w apps/web && rm -rf node_modules package-lock.json"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "~5.3.0"
  }
}
