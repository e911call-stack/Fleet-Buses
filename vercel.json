{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build -w fleetguard-web",
  "devCommand": "npm run dev -w fleetguard-web",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "public": false,
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "regions": ["iad1"],
  "functions": {
    "src/pages/api/**": {
      "maxDuration": 30
    }
  }
}
